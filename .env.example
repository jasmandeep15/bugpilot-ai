VITE_API_BASE_URL=http://127.0.0.1:8080

# Backend-only values. Do not expose OPENAI_API_KEY in frontend hosting.
BUGPILOT_AI_PROVIDER=deterministic
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
SPRING_DATASOURCE_URL=jdbc:h2:mem:bugpilot;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
